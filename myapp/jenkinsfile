pipeline {
    agent any
    environment {
        DOCKER_CREDENTIALS = credentials('dockerhub-creds')
        GITHUB_CREDENTIALS = credentials('github-creds')
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/piyush46732/application-code.git',
                    credentialsId: 'github-creds'
            }
        }
        stage('Build Docker Image') {
            steps {
                sh """
                echo $DOCKER_CREDENTIALS_PSW | docker login -u $DOCKER_CREDENTIALS_USR --password-stdin
                docker build -t piyush8398/myapp:${BUILD_NUMBER} .
                docker push piyush8398/myapp:${BUILD_NUMBER}
                """
            }
        }
        stage('Deploy') {
            steps {
                sh './deploy.sh ${BUILD_NUMBER}'
            }
        }
    }
    post {
        success {
            echo "✅ Deployment successful"
        }
        failure {
            echo "❌ Deployment failed, rollback executed"
        }
    }
}
